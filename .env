# Porta local onde o seu servidor Express vai rodar
PORT=3000

# Chave secreta usada pelo JWT para assinar e validar os tokens de acesso (pulseiras VIP)
JWT_SECRET=sua_chave_secreta_super_segura_aqui

# Nome do banco de dados que você criou no MySQL
DB_NAME=mvc

# Usuário padrão do seu banco de dados MySQL (geralmente 'root')
DB_USER=root

# Senha do seu banco de dados (vazia por padrão no XAMPP/Wamp; preencha se o seu tiver)
DB_PASS=

# Onde o banco de dados está rodando (localhost significa na sua própria máquina)
DB_HOST=localhost